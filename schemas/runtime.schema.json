{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sadl.dev/schemas/runtime.schema.json",
  "title": "SADL Local Runtime",
  "type": "object",
  "required": [
    "schemaVersion",
    "sadlVersion",
    "activeSession",
    "taskMetrics",
    "locks"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "string"
    },
    "sadlVersion": {
      "type": "string"
    },
    "activeSession": {
      "type": "object",
      "required": [
        "sessionId",
        "agentId",
        "activeTask",
        "startedAt"
      ],
      "properties": {
        "sessionId": {
          "type": [
            "string",
            "null"
          ]
        },
        "agentId": {
          "type": [
            "string",
            "null"
          ]
        },
        "taskId": {
          "type": [
            "string",
            "null"
          ]
        },
        "requirementIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "activeTask": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "type": [
            "string",
            "null"
          ]
        },
        "blocked": {
          "type": "boolean"
        },
        "nextAction": {
          "type": [
            "string",
            "null"
          ]
        },
        "startedAt": {
          "type": [
            "string",
            "null"
          ]
        },
        "updatedAt": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "taskMetrics": {
      "type": "object",
      "patternProperties": {
        "^TASK-[0-9]+$": {
          "type": "object",
          "properties": {
            "consecutiveFailures": {
              "type": "integer",
              "minimum": 0
            },
            "validationFailures": {
              "type": "integer",
              "minimum": 0
            },
            "commandTimeouts": {
              "type": "integer",
              "minimum": 0
            },
            "lastErrorHash": {
              "type": [
                "string",
                "null"
              ]
            },
            "lastCommandHash": {
              "type": [
                "string",
                "null"
              ]
            },
            "lastFailedCommand": {
              "type": [
                "string",
                "null"
              ]
            },
            "lastFailureAt": {
              "type": [
                "string",
                "null"
              ]
            },
            "blockedAt": {
              "type": [
                "string",
                "null"
              ]
            },
            "blockedReason": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "locks": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": true
}
